<UserControl x:Class="GitContextMenu.UI.Views.BranchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Local branches -->
        <TextBlock Grid.Row="0" Text="LOCAL BRANCHES" Style="{StaticResource SubtleText}" Margin="0,0,0,4"/>

        <ListBox Grid.Row="1" ItemsSource="{Binding LocalBranches}"
                 SelectedItem="{Binding SelectedBranch}"
                 MaxHeight="200" Margin="0,0,0,8">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="* " Foreground="{StaticResource BrushGreen}"
                                   FontWeight="Bold"
                                   Visibility="{Binding IsCurrent, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Text="{Binding Name}"
                                   FontWeight="{Binding IsCurrent, Converter={StaticResource BoolNegate}, ConverterParameter=Bold}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Normal"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text=" → " Foreground="{StaticResource BrushOverlay0}"
                                   Visibility="{Binding Upstream, Converter={StaticResource StringToVisibility}}"/>
                        <TextBlock Text="{Binding Upstream}" Foreground="{StaticResource BrushOverlay0}" FontSize="11"
                                   Visibility="{Binding Upstream, Converter={StaticResource StringToVisibility}}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Checkout" Command="{Binding CheckoutCommand}"
                    Style="{StaticResource PrimaryButton}"/>
            <Button Content="+ New Branch" Command="{Binding ToggleNewBranchPanelCommand}"
                    Margin="8,0,0,0"/>
            <Button Content="Refresh" Command="{Binding RefreshCommand}"
                    Margin="8,0,0,0"/>
        </StackPanel>

        <!-- New branch panel -->
        <Grid Grid.Row="3" Margin="0,0,0,8"
              Visibility="{Binding ShowNewBranchPanel, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding NewBranchName, UpdateSourceTrigger=PropertyChanged}" Padding="8,6"/>
            <Button Grid.Column="1" Content="Create" Margin="8,0,0,0"
                    Command="{Binding CreateBranchCommand}"
                    Style="{StaticResource PrimaryButton}"/>
        </Grid>

        <!-- Remote branches (collapsible) -->
        <Expander Grid.Row="4" Header="Remote Branches" Foreground="{StaticResource BrushSubtext}">
            <ListBox ItemsSource="{Binding RemoteBranches}" MaxHeight="150">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource BrushOverlay0}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Expander>
    </Grid>
</UserControl>
