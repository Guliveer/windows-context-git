<UserControl x:Class="GitContextMenu.UI.Views.OperationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GitContextMenu.UI.ViewModels">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="Run" Command="{Binding RunCommand}"
                    Style="{StaticResource PrimaryButton}"
                    IsEnabled="{Binding IsRunning, Converter={StaticResource BoolNegate}}"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}" Margin="8,0,0,0"
                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}"/>
        </StackPanel>

        <!-- Output console -->
        <Border Grid.Row="1" Background="{StaticResource BrushMantle}"
                BorderBrush="{StaticResource BrushSurface0}" BorderThickness="1"
                CornerRadius="4">
            <ScrollViewer x:Name="Scroll" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Lines}" Padding="12">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:OutputLine}">
                            <TextBlock Text="{Binding Text}"
                                       FontFamily="Consolas, Courier New"
                                       FontSize="12"
                                       Foreground="{Binding IsError, Converter={StaticResource IsErrorToBrush}}"
                                       TextWrapping="Wrap"
                                       Margin="0,1"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
