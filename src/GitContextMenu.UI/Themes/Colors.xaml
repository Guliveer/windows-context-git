<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- OLED Dark / Slate palette — from UI/UX Pro Max design system -->
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="BrushBg"        Color="#0F172A"/>  <!-- głębokie tło -->
    <SolidColorBrush x:Key="BrushSurface"   Color="#1E293B"/>  <!-- karty, panele -->
    <SolidColorBrush x:Key="BrushElevated"  Color="#334155"/>  <!-- hover, zaznaczenie -->
    <SolidColorBrush x:Key="BrushBorder"    Color="#475569"/>  <!-- obramowania -->

    <!-- Tekst -->
    <SolidColorBrush x:Key="BrushText"      Color="#F8FAFC"/>  <!-- primary text -->
    <SolidColorBrush x:Key="BrushSubtext"   Color="#CBD5E1"/>  <!-- secondary text -->
    <SolidColorBrush x:Key="BrushMuted"     Color="#64748B"/>  <!-- muted / placeholder -->

    <!-- Akcenty semantyczne -->
    <SolidColorBrush x:Key="BrushAccent"    Color="#22C55E"/>  <!-- akcja główna: zielony -->
    <SolidColorBrush x:Key="BrushAccentFg"  Color="#052E16"/>  <!-- tekst na zielonym -->
    <SolidColorBrush x:Key="BrushBlue"      Color="#60A5FA"/>  <!-- info, branch -->
    <SolidColorBrush x:Key="BrushYellow"    Color="#FBBF24"/>  <!-- ostrzeżenie, ahead/behind -->
    <SolidColorBrush x:Key="BrushRed"       Color="#F87171"/>  <!-- błąd, usunięty -->
    <SolidColorBrush x:Key="BrushGreen"     Color="#4ADE80"/>  <!-- sukces, dodany -->
    <SolidColorBrush x:Key="BrushOrange"    Color="#FB923C"/>  <!-- zmodyfikowany -->

    <!-- Overlay -->
    <SolidColorBrush x:Key="BrushOverlay0"  Color="#64748B"/>

    <!-- Kompatybilność ze starym kodem -->
    <SolidColorBrush x:Key="BrushBase"      Color="#0F172A"/>
    <SolidColorBrush x:Key="BrushMantle"    Color="#0B1120"/>
    <SolidColorBrush x:Key="BrushSurface0"  Color="#1E293B"/>
    <SolidColorBrush x:Key="BrushSurface1"  Color="#334155"/>
    <SolidColorBrush x:Key="BrushCrust"     Color="#060D1A"/>

</ResourceDictionary>
